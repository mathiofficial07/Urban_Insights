# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5001

# Model Configuration
MODEL_DIR=./models
DATA_DIR=./data

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/ml_service.log

# ML Model Parameters
MAX_FEATURES=5000
N_ESTIMATORS=100
N_CLUSTERS=10

# API Configuration
API_VERSION=v1
CORS_ORIGINS=*

# Database Configuration (if needed for direct DB access)
# MONGODB_URI=mongodb://localhost:27017/urban-insights

# Performance Configuration
MAX_WORKERS=4
REQUEST_TIMEOUT=30
